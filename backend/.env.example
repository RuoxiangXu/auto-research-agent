# LLM Configuration
LLM_PROVIDER=custom                    # ollama | lmstudio | custom
LLM_MODEL_ID=your-model-id            # Model name/ID
LLM_API_KEY=your-api-key              # API key for OpenAI-compatible providers
LLM_BASE_URL=https://your-api-url/v1  # Base URL for OpenAI-compatible API

# Search Configuration
SEARCH_API=tavily                      # tavily | duckduckgo | mcp

# Tavily API
TAVILY_API_KEY=your-tavily-api-key

# MCP Search Server (optional, used when SEARCH_API=mcp)
MCP_SERVER_COMMAND=npx
MCP_SERVER_ARGS=-y,tavily-mcp
MCP_TOOL_NAME=tavily_search

# Research Settings
MAX_SEARCH_RESULTS=5
MAX_RETRY_COUNT=1

# Server Configuration
HOST=0.0.0.0
PORT=8000
